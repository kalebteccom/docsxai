---
// The branded 404 page. A file-based /404 route (instead of a docs-collection
// 404 entry) for two load-bearing reasons: Astro writes a fixed /404 route to
// `404.html` (the file Netlify serves for unmatched paths), while the docs
// catch-all would emit `404/index.html`; and it avoids the route conflict with
// Starlight's injected 404 route, which is disabled in astro.config.mjs.
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
---

<StarlightPage
  frontmatter={{
    title: "Page not found",
    description: "That page does not exist.",
    template: "splash",
    editUrl: false,
    lastUpdated: false,
  }}
>
  <div class="docsx-404 not-content">
    <p class="docsx-kicker">Error 404</p>
    <div class="docsx-404-code">
      4<span class="x">0</span>4
    </div>
    <div class="docsx-404-msg">That page does not exist, or it moved.</div>
    <div class="docsx-cta docsx-cta--center">
      <a href="/" class="docsx-btn docsx-btn--primary"> Back home </a>
      <a href="/getting-started/introduction/" class="docsx-btn docsx-btn--ghost">
        Getting started
      </a>
      <a href="/reference/cli/" class="docsx-btn docsx-btn--ghost"> CLI reference </a>
    </div>
  </div>
</StarlightPage>
