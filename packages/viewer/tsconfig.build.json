{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "sourceMap": false,
    "inlineSourceMap": false,
    "declarationMap": false
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/__tests__/**",
    "src/**/__fixtures__/**",
    // browser-side module; reaches dist only as the esbuild IIFE at dist/generated/overlay.js
    "src/overlay-runtime.ts"
  ]
}
