{
  "name": "@kalebtec/docsxai-viewer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vitest-based interactive docs-app generator: overlays arrows + popups from annotations.json over clean screenshots at render time.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalebteccom/docsxai.git",
    "directory": "packages/viewer"
  },
  "homepage": "https://github.com/kalebteccom/docsxai#readme",
  "bugs": "https://github.com/kalebteccom/docsxai/issues",
  "keywords": ["docsxai", "documentation", "playwright", "claude-code", "agent"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "docsxai-viewer": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  }
}
