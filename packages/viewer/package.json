{
  "name": "@kalebtec/docsxai-viewer",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Interactive docs-app generator + burned-annotation renderer: overlays (or bakes) halos, badges and callouts from annotations.json over clean screenshots.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalebteccom/docsxai.git",
    "directory": "packages/viewer"
  },
  "homepage": "https://github.com/kalebteccom/docsxai#readme",
  "bugs": "https://github.com/kalebteccom/docsxai/issues",
  "keywords": [
    "docsxai",
    "documentation",
    "playwright",
    "claude-code",
    "agent"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "bin": {
    "docsxai-viewer": "./dist/index.js"
  },
  "scripts": {
    "build": "node scripts/bundle-overlay.mjs && tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/bundle-overlay.mjs && vitest run"
  },
  "devDependencies": {
    "@astrojs/starlight": "0.40.0",
    "@types/node": "^20.14.0",
    "astro": "6.4.6",
    "esbuild": "^0.28.1",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "micromark": "^4.0.2",
    "satori": "^0.26.0"
  }
}
