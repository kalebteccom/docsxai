{
  "name": "@docsxai/skill",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Optional colocated .claude/skills/ fallback that delegates to the installed plugin. Secondary path for teams that want to vendor / version-pin.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalebteccom/docsxai.git",
    "directory": "packages/skill"
  },
  "homepage": "https://github.com/kalebteccom/docsxai#readme",
  "bugs": "https://github.com/kalebteccom/docsxai/issues",
  "keywords": [
    "docsxai",
    "documentation",
    "playwright",
    "claude-code",
    "agent"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "vitest": "^2.0.0"
  }
}
