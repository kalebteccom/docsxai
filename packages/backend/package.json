{
  "name": "@kalebtec/docsxai-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Authenticated service that persists doc packs (projects, revisions, flow-files, screenshots, annotations, style artifacts, run history). REST + per-resource endpoints; OAuth 2.1 auth.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalebteccom/docsxai.git",
    "directory": "packages/backend"
  },
  "homepage": "https://github.com/kalebteccom/docsxai#readme",
  "bugs": "https://github.com/kalebteccom/docsxai/issues",
  "keywords": [
    "docsxai",
    "documentation",
    "playwright",
    "claude-code",
    "agent"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "docsxai-backend": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "vitest": "^2.0.0"
  }
}
