{
  "name": "docsxai",
  "version": "0.2.0",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "Deterministic screenshot docs for web apps — the batteries-included CLI. Meta-package over @docsxai/engine (the docsxai CLI + library) and @docsxai/viewer (the renderer `docsxai render` spawns).",
  "license": "Apache-2.0",
  "author": "Kalebtec <security@kalebtec.com>",
  "homepage": "https://github.com/kalebteccom/docsxai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalebteccom/docsxai.git",
    "directory": "packages/docsxai"
  },
  "bugs": {
    "url": "https://github.com/kalebteccom/docsxai/issues"
  },
  "keywords": [
    "docsxai",
    "documentation",
    "playwright",
    "claude-code",
    "agent"
  ],
  "main": "index.mjs",
  "types": "index.d.mts",
  "exports": {
    ".": {
      "types": "./index.d.mts",
      "default": "./index.mjs"
    }
  },
  "bin": {
    "docsxai": "./bin.mjs"
  },
  "files": [
    "bin.mjs",
    "index.mjs",
    "index.d.mts",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@docsxai/engine": "workspace:*",
    "@docsxai/viewer": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=26"
  }
}
