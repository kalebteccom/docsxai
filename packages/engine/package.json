{
  "name": "@docsxai/engine",
  "version": "0.2.0",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "description": "LLM-agnostic engine: flow-file parser + deterministic runtime + the docsxai CLI + the target-site auth-strategy layer.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalebteccom/docsxai.git",
    "directory": "packages/engine"
  },
  "homepage": "https://github.com/kalebteccom/docsxai#readme",
  "bugs": "https://github.com/kalebteccom/docsxai/issues",
  "keywords": [
    "docsxai",
    "documentation",
    "playwright",
    "claude-code",
    "agent"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "docsxai": "./dist/cli.js"
  },
  "scripts": {
    "build": "node ../../scripts/clean-dist.mjs && tsc -b tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "playwright-core": "^1.61.0",
    "pngjs": "^7.0.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@docsxai/backend": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/pngjs": "^6.0.5",
    "vitest": "^2.0.0"
  },
  "author": "Kalebtec <security@kalebtec.com>",
  "engines": {
    "node": ">=20"
  }
}
