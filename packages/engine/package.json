{
  "name": "@kalebtec/site-docs-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LLM-agnostic engine: calibration pipeline stages (discovery, mapping+testing, commit) + flow-file parser/runtime + the target-site auth-strategy layer.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kalebteccom/automated-site-documentation-bot.git",
    "directory": "packages/engine"
  },
  "homepage": "https://github.com/kalebteccom/automated-site-documentation-bot#readme",
  "bugs": "https://github.com/kalebteccom/automated-site-documentation-bot/issues",
  "keywords": ["site-docs", "documentation", "playwright", "claude-code", "agent"],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "site-docs": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "playwright-core": "^1.47.0",
    "yaml": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@kalebtec/site-docs-backend": "workspace:*"
  }
}
